<%- include("partials/header") %>

<section class="submit-hero">
  <div class="container py-5 text-center">
    <h1 class="hero-title mb-2">New Review</h1>
    <p class="hero-copy mx-auto">Share your Max and Margo review in one place.</p>
  </div>
</section>

<div class="container py-5 submit-page-wrap">
  <div class="row g-4 justify-content-center">
    <div class="col-12 col-xl-8">
      <h2 class="h3 mb-4">Coffee Details</h2>

      <% if (errors.length > 0) { %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% errors.forEach(function (error) { %>
              <li><%= error.msg %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form action="/submit" method="POST" class="card shadow-sm p-4 submit-form-card" enctype="multipart/form-data" novalidate>
        <div class="mb-4">
          <label for="name" class="form-label">Name of the place *</label>
          <input
            type="text"
            class="form-control"
            id="name"
            name="name"
            maxlength="120"
            value="<%= values.name %>"
            required
          />
        </div>

        <div class="mb-4">
          <label for="location" class="form-label">Location</label>
          <input
            type="text"
            class="form-control"
            id="location"
            name="location"
            maxlength="160"
            placeholder="City, neighborhood, or address"
            value="<%= values.location %>"
          />
        </div>

        <% if (isAdmin) { %>
          <div class="row g-4 mb-4">
            <div class="col-12">
              <div class="review-block">
                <h3 class="h4 mb-3">Max Review</h3>
                <div class="mb-3">
                  <label for="maxOrdered" class="form-label">What Max ordered</label>
                  <input
                    type="text"
                    class="form-control"
                    id="maxOrdered"
                    name="maxOrdered"
                    maxlength="200"
                    value="<%= values.maxOrdered %>"
                  />
                </div>

                <div class="bean-grid mb-3">
                  <div>
                    <label class="form-label">Max Cost</label>
                    <div class="bean-rating" data-initial="<%= values.maxCostRating %>">
                      <input type="hidden" name="maxCostRating" value="<%= values.maxCostRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Max cost rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>

                  <div>
                    <label class="form-label">Max Taste</label>
                    <div class="bean-rating" data-initial="<%= values.maxTasteRating %>">
                      <input type="hidden" name="maxTasteRating" value="<%= values.maxTasteRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Max taste rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>

                  <div>
                    <label class="form-label">Max Location</label>
                    <div class="bean-rating" data-initial="<%= values.maxLocationRating %>">
                      <input type="hidden" name="maxLocationRating" value="<%= values.maxLocationRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Max location rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>

                  <div>
                    <label class="form-label">Max Vibe</label>
                    <div class="bean-rating" data-initial="<%= values.maxVibeRating %>">
                      <input type="hidden" name="maxVibeRating" value="<%= values.maxVibeRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Max vibe rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-12">
              <div class="review-block">
                <h3 class="h4 mb-3">Margo Review</h3>
                <div class="mb-3">
                  <label for="margoOrdered" class="form-label">What Margo ordered</label>
                  <input
                    type="text"
                    class="form-control"
                    id="margoOrdered"
                    name="margoOrdered"
                    maxlength="200"
                    value="<%= values.margoOrdered %>"
                  />
                </div>

                <div class="bean-grid mb-3">
                  <div>
                    <label class="form-label">Margo Cost</label>
                    <div class="bean-rating" data-initial="<%= values.margoCostRating %>">
                      <input type="hidden" name="margoCostRating" value="<%= values.margoCostRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo cost rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>

                  <div>
                    <label class="form-label">Margo Taste</label>
                    <div class="bean-rating" data-initial="<%= values.margoTasteRating %>">
                      <input type="hidden" name="margoTasteRating" value="<%= values.margoTasteRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo taste rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>

                  <div>
                    <label class="form-label">Margo Location</label>
                    <div class="bean-rating" data-initial="<%= values.margoLocationRating %>">
                      <input type="hidden" name="margoLocationRating" value="<%= values.margoLocationRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo location rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>

                  <div>
                    <label class="form-label">Margo Vibe</label>
                    <div class="bean-rating" data-initial="<%= values.margoVibeRating %>">
                      <input type="hidden" name="margoVibeRating" value="<%= values.margoVibeRating %>" />
                      <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo vibe rating out of ten">
                        <% for (let i = 1; i <= 10; i += 1) { %>
                          <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                            <span class="bean-dot"></span>
                          </button>
                        <% } %>
                      </div>
                      <span class="bean-rating-value">0/10</span>
                    </div>
                  </div>
                </div>

                <div class="form-text mt-2">Admins can submit Max and Margo in one action.</div>
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label for="notes" class="form-label">Notes</label>
            <textarea
              class="form-control"
              id="notes"
              name="notes"
              rows="3"
              maxlength="500"
              placeholder="Shared notes for this place"
            ><%= values.notes %></textarea>
          </div>
        <% } else { %>
          <div class="mb-3">
            <label for="ordered" class="form-label">What was ordered</label>
            <input
              type="text"
              class="form-control"
              id="ordered"
              name="ordered"
              maxlength="200"
              placeholder="e.g. Oat flat white and a croissant"
              value="<%= values.ordered %>"
            />
          </div>

          <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
              <label for="costRating" class="form-label">Cost *</label>
              <input
                type="number"
                class="form-control"
                id="costRating"
                name="costRating"
                min="0"
                max="10"
                step="0.1"
                value="<%= values.costRating %>"
                required
              />
            </div>
            <div class="col-6 col-md-3">
              <label for="tasteRating" class="form-label">Taste *</label>
              <input
                type="number"
                class="form-control"
                id="tasteRating"
                name="tasteRating"
                min="0"
                max="10"
                step="0.1"
                value="<%= values.tasteRating %>"
                required
              />
            </div>
            <div class="col-6 col-md-3">
              <label for="locationRating" class="form-label">Location *</label>
              <input
                type="number"
                class="form-control"
                id="locationRating"
                name="locationRating"
                min="0"
                max="10"
                step="0.1"
                value="<%= values.locationRating %>"
                required
              />
            </div>
            <div class="col-6 col-md-3">
              <label for="vibeRating" class="form-label">Vibe *</label>
              <input
                type="number"
                class="form-control"
                id="vibeRating"
                name="vibeRating"
                min="0"
                max="10"
                step="0.1"
                value="<%= values.vibeRating %>"
                required
              />
            </div>
            <div class="col-12">
              <div class="form-text">Rate each category from 0 to 10. The overall score is their average.</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="notes" class="form-label">Notes</label>
            <textarea
              class="form-control"
              id="notes"
              name="notes"
              rows="3"
              maxlength="500"
              placeholder="What did you think?"
            ><%= values.notes %></textarea>
          </div>
        <% } %>

        <div class="mb-3">
          <label for="images" class="form-label">Photo</label>
          <input
            type="file"
            class="form-control"
            id="images"
            name="images"
            accept="image/*"
          />
          <div class="form-text">Upload one image (max 5&nbsp;MB). Uploading a new one replaces the existing photo.</div>
        </div>

        <div class="d-flex gap-2 submit-actions">
          <button type="submit" class="btn btn-primary px-4">Publish Review</button>
          <a href="/" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    function clampRating(value) {
      var clamped = Math.max(0, Math.min(10, Number(value) || 0));
      return Math.round(clamped * 2) / 2;
    }

    function formatRating(value) {
      var normalized = clampRating(value);
      if (Math.abs(normalized - Math.round(normalized)) < 0.001) {
        return String(Math.round(normalized));
      }
      return normalized.toFixed(1);
    }

    function initBeanRating(container) {
      var hidden = container.querySelector('input[type="hidden"]');
      var buttons = Array.prototype.slice.call(container.querySelectorAll('.bean-btn'));
      var valueEl = container.querySelector('.bean-rating-value');
      var initialRaw = parseFloat(container.getAttribute('data-initial') || hidden.value || '0');
      var current = Number.isFinite(initialRaw) ? clampRating(initialRaw) : 0;

      function render(next) {
        current = clampRating(next);
        hidden.value = current ? String(current) : '';
        valueEl.textContent = formatRating(current || 0) + '/10';

        buttons.forEach(function (btn) {
          var value = Number(btn.getAttribute('data-value') || '0');
          var active = value <= current;
          var half = !active && value - 0.5 <= current;
          btn.classList.toggle('active', active);
          btn.classList.toggle('half', half);
          btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          render(Number(btn.getAttribute('data-value') || '0'));
        });
        btn.addEventListener('dblclick', function (event) {
          event.preventDefault();
          render(Number(btn.getAttribute('data-value') || '0') - 0.5);
        });
      });

      render(current);
    }

    Array.prototype.slice.call(document.querySelectorAll('.bean-rating')).forEach(initBeanRating);
  })();
</script>

<%- include("partials/footer") %>
