<%- include("partials/header") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-7">
      <h1 class="h3 mb-4">Submit a Coffee Place</h1>

      <% if (errors.length > 0) { %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% errors.forEach(function (error) { %>
              <li><%= error.msg %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form action="/submit" method="POST" class="card shadow-sm p-4" novalidate>
        <div class="mb-3">
          <label for="name" class="form-label">Name of the place *</label>
          <input
            type="text"
            class="form-control"
            id="name"
            name="name"
            maxlength="120"
            value="<%= values.name %>"
            required
          />
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            type="text"
            class="form-control"
            id="location"
            name="location"
            maxlength="160"
            placeholder="City, neighborhood, or address"
            value="<%= values.location %>"
          />
        </div>

        <div class="mb-3">
          <label for="ordered" class="form-label">What was ordered</label>
          <input
            type="text"
            class="form-control"
            id="ordered"
            name="ordered"
            maxlength="200"
            placeholder="e.g. Oat flat white and a croissant"
            value="<%= values.ordered %>"
          />
        </div>

        <div class="row g-3 mb-3">
          <div class="col-6 col-md-3">
            <label for="costRating" class="form-label">Cost *</label>
            <input
              type="number"
              class="form-control"
              id="costRating"
              name="costRating"
              min="0"
              max="10"
              step="0.1"
              value="<%= values.costRating %>"
              required
            />
          </div>
          <div class="col-6 col-md-3">
            <label for="tasteRating" class="form-label">Taste *</label>
            <input
              type="number"
              class="form-control"
              id="tasteRating"
              name="tasteRating"
              min="0"
              max="10"
              step="0.1"
              value="<%= values.tasteRating %>"
              required
            />
          </div>
          <div class="col-6 col-md-3">
            <label for="locationRating" class="form-label">Location *</label>
            <input
              type="number"
              class="form-control"
              id="locationRating"
              name="locationRating"
              min="0"
              max="10"
              step="0.1"
              value="<%= values.locationRating %>"
              required
            />
          </div>
          <div class="col-6 col-md-3">
            <label for="vibeRating" class="form-label">Vibe *</label>
            <input
              type="number"
              class="form-control"
              id="vibeRating"
              name="vibeRating"
              min="0"
              max="10"
              step="0.1"
              value="<%= values.vibeRating %>"
              required
            />
          </div>
          <div class="col-12">
            <div class="form-text">Rate each category from 0 to 10. The overall score is their average.</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="notes" class="form-label">Notes</label>
          <textarea
            class="form-control"
            id="notes"
            name="notes"
            rows="3"
            maxlength="500"
            placeholder="What did you think?"
          ><%= values.notes %></textarea>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">Submit</button>
          <a href="/" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
