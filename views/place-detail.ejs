<%- include("partials/header") %>

<section class="container py-5">
  <div class="mb-3">
    <a href="/reviews" class="btn btn-sm btn-outline-secondary">Back to Reviews</a>
  </div>

  <article class="detail-shell">
    <div class="detail-header">
      <h1 class="mb-1"><%= place.name %></h1>
      <p class="text-body-secondary mb-0"><%= place.location || "Location not listed" %></p>
      <% if (typeof user !== "undefined" && user && user.isAdmin) { %>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleCriticEdit()">Edit Max + Margo</button>
          <form action="/places/<%= place.anchorId %>/consolidated?_method=DELETE" method="POST" onsubmit="return confirm('Delete this place for both Max and Margo?');">
            <button type="submit" class="btn btn-sm btn-outline-danger">Delete Place</button>
          </form>
        </div>
      <% } %>
    </div>

    <div class="detail-grid">
      <div class="detail-photo">
        <% if (place.image) { %>
          <img
            src="/places/<%= place.anchorId %>/image/<%= place.image._id %>"
            alt="Photo of <%= place.name %>"
            loading="lazy"
          />
        <% } else { %>
          <div class="featured-image featured-image-placeholder">No photo yet</div>
        <% } %>
      </div>

      <div class="detail-ratings">
        <div class="review-columns mb-3">
          <section class="review-column">
            <h3>Max</h3>
            <% if (place.maxReview) { %>
              <p class="review-ordered"><strong>Ordered:</strong> <%= place.maxReview.ordered || "-" %></p>
              <ul class="review-metrics list-unstyled">
                <li>
                  Cost
                  <span class="metric-score-with-beans">
                    <span><%= place.maxReview.costRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Taste
                  <span class="metric-score-with-beans">
                    <span><%= place.maxReview.tasteRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Location
                  <span class="metric-score-with-beans">
                    <span><%= place.maxReview.locationRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Vibe
                  <span class="metric-score-with-beans">
                    <span><%= place.maxReview.vibeRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Overall
                  <span class="metric-score-with-beans">
                    <span><%= place.maxReview.overallRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
              </ul>
            <% } else { %>
              <p class="text-body-secondary small">No review yet.</p>
            <% } %>
          </section>

          <section class="review-column">
            <h3>Margo</h3>
            <% if (place.margoReview) { %>
              <p class="review-ordered"><strong>Ordered:</strong> <%= place.margoReview.ordered || "-" %></p>
              <ul class="review-metrics list-unstyled">
                <li>
                  Cost
                  <span class="metric-score-with-beans">
                    <span><%= place.margoReview.costRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Taste
                  <span class="metric-score-with-beans">
                    <span><%= place.margoReview.tasteRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Location
                  <span class="metric-score-with-beans">
                    <span><%= place.margoReview.locationRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Vibe
                  <span class="metric-score-with-beans">
                    <span><%= place.margoReview.vibeRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
                <li>
                  Overall
                  <span class="metric-score-with-beans">
                    <span><%= place.margoReview.overallRating.toFixed(1) %></span>
                    <span class="mini-bean active" aria-hidden="true"></span>
                  </span>
                </li>
              </ul>
            <% } else { %>
              <p class="text-body-secondary small">No review yet.</p>
            <% } %>
          </section>
        </div>

        <% if (place.notes) { %>
          <p class="mb-3"><strong>Notes:</strong> <%= place.notes %></p>
        <% } %>

        <div class="community-summary big">
          <p class="meta-label mb-1">Community Rating</p>
          <p class="community-score">
            <%= place.communityRating !== null ? place.communityRating.toFixed(1) + "/10" : "No ratings yet" %>
          </p>
          <p class="text-body-secondary small mb-0"><%= place.communityReviewCount %> community review<%= place.communityReviewCount === 1 ? "" : "s" %></p>
        </div>

        <% if (typeof user !== "undefined" && user && user.isAdmin) { %>
          <div id="critic-edit-panel" class="card coffee-card p-3 mt-3<%= criticErrors.length ? "" : " d-none" %>">
            <h2 class="h5 mb-3">Edit Max + Margo Reviews</h2>
            <% if (criticErrors.length) { %>
              <div class="alert alert-danger py-2 px-3">
                <ul class="mb-0 ps-3">
                  <% criticErrors.forEach(function (error) { %>
                    <li><%= error.msg %></li>
                  <% }); %>
                </ul>
              </div>
            <% } %>

            <form action="/places/<%= place.anchorId %>/critics?_method=PUT" method="POST" enctype="multipart/form-data" novalidate>
              <div class="row g-2 mb-2">
                <div class="col-12 col-md-6">
                  <label class="form-label">Place Name</label>
                  <input type="text" class="form-control" name="name" maxlength="120" value="<%= criticValues.name %>" required />
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label">Location</label>
                  <input type="text" class="form-control" name="location" maxlength="160" value="<%= criticValues.location %>" />
                </div>
              </div>

              <div class="row g-2 mb-3">
                <div class="col-12"><h3 class="h6 mb-1">Max</h3></div>
                <div class="col-12">
                  <label class="form-label">Ordered</label>
                  <input type="text" class="form-control" name="maxOrdered" maxlength="200" value="<%= criticValues.maxOrdered %>" />
                </div>
                <div class="col-12">
                  <div class="bean-grid">
                    <div>
                      <label class="form-label">Cost</label>
                      <div class="bean-rating" data-initial="<%= criticValues.maxCostRating %>">
                        <input type="hidden" name="maxCostRating" value="<%= criticValues.maxCostRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Max cost rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                    <div>
                      <label class="form-label">Taste</label>
                      <div class="bean-rating" data-initial="<%= criticValues.maxTasteRating %>">
                        <input type="hidden" name="maxTasteRating" value="<%= criticValues.maxTasteRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Max taste rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                    <div>
                      <label class="form-label">Location</label>
                      <div class="bean-rating" data-initial="<%= criticValues.maxLocationRating %>">
                        <input type="hidden" name="maxLocationRating" value="<%= criticValues.maxLocationRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Max location rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                    <div>
                      <label class="form-label">Vibe</label>
                      <div class="bean-rating" data-initial="<%= criticValues.maxVibeRating %>">
                        <input type="hidden" name="maxVibeRating" value="<%= criticValues.maxVibeRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Max vibe rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="row g-2 mb-3">
                <div class="col-12"><h3 class="h6 mb-1">Margo</h3></div>
                <div class="col-12">
                  <label class="form-label">Ordered</label>
                  <input type="text" class="form-control" name="margoOrdered" maxlength="200" value="<%= criticValues.margoOrdered %>" />
                </div>
                <div class="col-12">
                  <div class="bean-grid">
                    <div>
                      <label class="form-label">Cost</label>
                      <div class="bean-rating" data-initial="<%= criticValues.margoCostRating %>">
                        <input type="hidden" name="margoCostRating" value="<%= criticValues.margoCostRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo cost rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                    <div>
                      <label class="form-label">Taste</label>
                      <div class="bean-rating" data-initial="<%= criticValues.margoTasteRating %>">
                        <input type="hidden" name="margoTasteRating" value="<%= criticValues.margoTasteRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo taste rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                    <div>
                      <label class="form-label">Location</label>
                      <div class="bean-rating" data-initial="<%= criticValues.margoLocationRating %>">
                        <input type="hidden" name="margoLocationRating" value="<%= criticValues.margoLocationRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo location rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                    <div>
                      <label class="form-label">Vibe</label>
                      <div class="bean-rating" data-initial="<%= criticValues.margoVibeRating %>">
                        <input type="hidden" name="margoVibeRating" value="<%= criticValues.margoVibeRating %>" />
                        <div class="bean-rating-buttons" role="radiogroup" aria-label="Margo vibe rating out of ten">
                          <% for (let i = 1; i <= 10; i += 1) { %>
                            <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                              <span class="bean-dot"></span>
                            </button>
                          <% } %>
                        </div>
                        <span class="bean-rating-value">0/10</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea class="form-control" name="notes" rows="3" maxlength="500" placeholder="Shared notes for this place"><%= criticValues.notes %></textarea>
              </div>

              <div class="mb-3">
                <label class="form-label">Add photo</label>
                <input type="file" class="form-control" name="images" accept="image/*" />
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary">Save Changes</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleCriticEdit()">Cancel</button>
              </div>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </article>
</section>

<section id="community-reviews" class="container pb-5">
  <div class="row g-4">
    <div class="col-12 col-lg-5">
      <div class="card coffee-card p-4 community-reviews-list-card">
        <h2 class="h3 mb-3">Community Reviews</h2>
        <% if (place.communityReviews.length === 0) { %>
          <p class="text-body-secondary">No community reviews yet.</p>
        <% } else { %>
          <div class="community-list">
            <% place.communityReviews.forEach(function (review) { %>
              <article class="community-item">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                  <div>
                    <strong><%= review.author || "Anonymous" %></strong>
                    <% if (review.accountUsername) { %>
                      <a href="/users/<%= review.accountUsername %>" class="community-profile-link">@<%= review.accountUsername %></a>
                    <% } %>
                  </div>
                  <span class="rating-pill"><%= review.overallRating.toFixed(1) %><small>/10</small></span>
                </div>
                <% if (review.ordered) { %>
                  <p class="small mb-1"><strong>Ordered:</strong> <%= review.ordered %></p>
                <% } %>
                <div class="row row-cols-2 g-2 mb-2">
                  <div class="col"><div class="category-rating"><span class="category-label">Cost</span><span class="metric-score-with-beans"><span class="category-score"><%= review.costRating.toFixed(1) %></span><span class="mini-bean active" aria-hidden="true"></span></span></div></div>
                  <div class="col"><div class="category-rating"><span class="category-label">Taste</span><span class="metric-score-with-beans"><span class="category-score"><%= review.tasteRating.toFixed(1) %></span><span class="mini-bean active" aria-hidden="true"></span></span></div></div>
                  <div class="col"><div class="category-rating"><span class="category-label">Location</span><span class="metric-score-with-beans"><span class="category-score"><%= review.locationRating.toFixed(1) %></span><span class="mini-bean active" aria-hidden="true"></span></span></div></div>
                  <div class="col"><div class="category-rating"><span class="category-label">Vibe</span><span class="metric-score-with-beans"><span class="category-score"><%= review.vibeRating.toFixed(1) %></span><span class="mini-bean active" aria-hidden="true"></span></span></div></div>
                </div>
                <% if (review.notes) { %>
                  <p class="mb-0"><%= review.notes %></p>
                <% } %>
                <% if (typeof user !== "undefined" && user && user.isAdmin) { %>
                  <form action="/places/<%= place.anchorId %>/community-reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-2" onsubmit="return confirm('Delete this community review?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete Review</button>
                  </form>
                <% } %>
              </article>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="card coffee-card p-4 community-review-form-card">
        <h2 class="h4 mb-3">Leave Your Review</h2>

        <% if (typeof user !== "undefined" && user) { %>
          <% if (communityErrors.length) { %>
            <div class="alert alert-danger py-2 px-3">
              <ul class="mb-0 ps-3">
                <% communityErrors.forEach(function (error) { %>
                  <li><%= error.msg %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>

          <form action="/places/<%= place.anchorId %>/community-reviews" method="POST" novalidate>
            <div class="mb-2">
              <label class="form-label">Name</label>
              <input type="text" class="form-control" name="author" maxlength="60" value="<%= communityValues.author %>" />
            </div>
            <div class="mb-2">
              <label class="form-label">Ordered</label>
              <input type="text" class="form-control" name="ordered" maxlength="200" value="<%= communityValues.ordered %>" />
            </div>
            <div class="bean-grid mb-3">
              <div>
                <label class="form-label">Cost *</label>
                <div class="bean-rating" data-initial="<%= communityValues.costRating %>">
                  <input type="hidden" name="costRating" value="<%= communityValues.costRating %>" />
                  <div class="bean-rating-buttons" role="radiogroup" aria-label="Cost rating out of ten">
                    <% for (let i = 1; i <= 10; i += 1) { %>
                      <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                        <span class="bean-dot"></span>
                      </button>
                    <% } %>
                  </div>
                  <span class="bean-rating-value">0/10</span>
                </div>
              </div>

              <div>
                <label class="form-label">Taste *</label>
                <div class="bean-rating" data-initial="<%= communityValues.tasteRating %>">
                  <input type="hidden" name="tasteRating" value="<%= communityValues.tasteRating %>" />
                  <div class="bean-rating-buttons" role="radiogroup" aria-label="Taste rating out of ten">
                    <% for (let i = 1; i <= 10; i += 1) { %>
                      <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                        <span class="bean-dot"></span>
                      </button>
                    <% } %>
                  </div>
                  <span class="bean-rating-value">0/10</span>
                </div>
              </div>

              <div>
                <label class="form-label">Location *</label>
                <div class="bean-rating" data-initial="<%= communityValues.locationRating %>">
                  <input type="hidden" name="locationRating" value="<%= communityValues.locationRating %>" />
                  <div class="bean-rating-buttons" role="radiogroup" aria-label="Location rating out of ten">
                    <% for (let i = 1; i <= 10; i += 1) { %>
                      <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                        <span class="bean-dot"></span>
                      </button>
                    <% } %>
                  </div>
                  <span class="bean-rating-value">0/10</span>
                </div>
              </div>

              <div>
                <label class="form-label">Vibe *</label>
                <div class="bean-rating" data-initial="<%= communityValues.vibeRating %>">
                  <input type="hidden" name="vibeRating" value="<%= communityValues.vibeRating %>" />
                  <div class="bean-rating-buttons" role="radiogroup" aria-label="Vibe rating out of ten">
                    <% for (let i = 1; i <= 10; i += 1) { %>
                      <button type="button" class="bean-btn" data-value="<%= i %>" aria-label="<%= i %> out of 10">
                        <span class="bean-dot"></span>
                      </button>
                    <% } %>
                  </div>
                  <span class="bean-rating-value">0/10</span>
                </div>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Notes</label>
              <textarea class="form-control" name="notes" rows="3" maxlength="500"><%= communityValues.notes %></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Submit Community Review</button>
          </form>
        <% } else { %>
          <p class="text-body-secondary mb-3">Log in to leave a community review.</p>
          <a href="/login" class="btn btn-outline-secondary">Log In</a>
        <% } %>
      </div>
    </div>
  </div>
</section>

<script>
  function toggleCriticEdit() {
    var panel = document.getElementById("critic-edit-panel");
    if (!panel) return;
    panel.classList.toggle("d-none");
  }

  (function () {
    function clampRating(value) {
      var clamped = Math.max(0, Math.min(10, Number(value) || 0));
      return Math.round(clamped * 2) / 2;
    }

    function formatRating(value) {
      var normalized = clampRating(value);
      if (Math.abs(normalized - Math.round(normalized)) < 0.001) {
        return String(Math.round(normalized));
      }
      return normalized.toFixed(1);
    }

    function initBeanRating(container) {
      var hidden = container.querySelector('input[type="hidden"]');
      var buttons = Array.prototype.slice.call(container.querySelectorAll('.bean-btn'));
      var valueEl = container.querySelector('.bean-rating-value');
      var initialRaw = parseFloat(container.getAttribute('data-initial') || hidden.value || '0');
      var current = Number.isFinite(initialRaw) ? clampRating(initialRaw) : 0;

      function render(next) {
        current = clampRating(next);
        hidden.value = current ? String(current) : '';
        valueEl.textContent = formatRating(current || 0) + '/10';

        buttons.forEach(function (btn) {
          var value = Number(btn.getAttribute('data-value') || '0');
          var active = value <= current;
          var half = !active && value - 0.5 <= current;
          btn.classList.toggle('active', active);
          btn.classList.toggle('half', half);
          btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          render(Number(btn.getAttribute('data-value') || '0'));
        });
        btn.addEventListener('dblclick', function (event) {
          event.preventDefault();
          render(Number(btn.getAttribute('data-value') || '0') - 0.5);
        });
      });

      render(current);
    }

    Array.prototype.slice.call(document.querySelectorAll('.bean-rating')).forEach(initBeanRating);
  })();
</script>

<%- include("partials/footer") %>
