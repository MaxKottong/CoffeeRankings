<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> · Coffee Rankings</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="d-flex flex-column min-vh-100 coffee-body">
    <nav class="navbar navbar-expand-lg coffee-navbar">
      <div class="container">
        <a class="navbar-brand" href="/">
          <span class="brand-script">max &amp; margo</span>
          <span class="brand-subtitle">coffee reviews</span>
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navContent"
          aria-controls="navContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navContent">
          <ul class="navbar-nav ms-auto align-items-lg-center">
            <li class="nav-item">
              <a class="nav-link" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/reviews">Reviews</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/#about">About Us</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/#contact">Contact</a>
            </li>
            <% if (typeof user !== "undefined" && user) { %>
              <li class="nav-item">
                <a class="btn btn-sm btn-primary ms-lg-2 mt-2 mt-lg-0" href="/submit">Submit a Place</a>
              </li>
              <li class="nav-item">
                <span class="nav-link small text-body-secondary"><%= user.email %></span>
              </li>
              <li class="nav-item">
                <form action="/logout" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-outline-secondary ms-lg-2">Log Out</button>
                </form>
              </li>
            <% } else { %>
              <li class="nav-item">
                <a class="btn btn-sm btn-outline-secondary ms-lg-2 mt-2 mt-lg-0" href="/login">Log In</a>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>
    <main class="flex-grow-1">
