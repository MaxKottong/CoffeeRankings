<div class="col-12 col-md-6 col-lg-4">
  <a class="card h-100 shadow-sm coffee-card coffee-card-link" id="place-<%= place.anchorId %>" href="/places/<%= place.anchorId %>">
    <% if (place.image) { %>
      <img
        src="/places/<%= place.anchorId %>/image/<%= place.image._id %>"
        class="d-block w-100 coffee-photo"
        alt="Photo of <%= place.name %>"
        loading="lazy"
      />
    <% } %>

    <div class="card-body d-flex flex-column">
      <% const communityStars = place.communityRating !== null ? Math.round(place.communityRating / 2) : 0; %>
      <div class="d-flex justify-content-between align-items-start mb-2">
        <span class="rank-badge">Rank #<%= index + 1 %></span>
        <span class="rating-pill" title="Community average rating out of 10">
          <%= place.communityRating !== null ? place.communityRating.toFixed(1) : "-" %><small>/10</small>
        </span>
      </div>

      <h3 class="h5 card-title mb-1"><%= place.name %></h3>
      <% if (place.location) { %>
        <p class="text-body-secondary small mb-3"><%= place.location %></p>
      <% } %>

      <div class="review-columns mb-3">
        <section class="review-column">
          <h4>Max</h4>
          <% if (place.maxReview) { %>
            <p class="review-ordered"><strong>Ordered:</strong> <%= place.maxReview.ordered || "-" %></p>
            <ul class="review-metrics list-unstyled">
              <li>Cost <span><%= place.maxReview.costRating.toFixed(1) %></span></li>
              <li>Taste <span><%= place.maxReview.tasteRating.toFixed(1) %></span></li>
              <li>Location <span><%= place.maxReview.locationRating.toFixed(1) %></span></li>
              <li>Vibe <span><%= place.maxReview.vibeRating.toFixed(1) %></span></li>
              <li>Overall <span><%= place.maxReview.overallRating.toFixed(1) %></span></li>
            </ul>
          <% } else { %>
            <p class="text-body-secondary small">No review yet.</p>
          <% } %>
        </section>

        <section class="review-column">
          <h4>Margo</h4>
          <% if (place.margoReview) { %>
            <p class="review-ordered"><strong>Ordered:</strong> <%= place.margoReview.ordered || "-" %></p>
            <ul class="review-metrics list-unstyled">
              <li>Cost <span><%= place.margoReview.costRating.toFixed(1) %></span></li>
              <li>Taste <span><%= place.margoReview.tasteRating.toFixed(1) %></span></li>
              <li>Location <span><%= place.margoReview.locationRating.toFixed(1) %></span></li>
              <li>Vibe <span><%= place.margoReview.vibeRating.toFixed(1) %></span></li>
              <li>Overall <span><%= place.margoReview.overallRating.toFixed(1) %></span></li>
            </ul>
          <% } else { %>
            <p class="text-body-secondary small">No review yet.</p>
          <% } %>
        </section>
      </div>

      <div class="community-summary mt-auto">
        <p class="meta-label mb-1">Community Rating</p>
        <p class="community-score">
          <%= place.communityRating !== null ? place.communityRating.toFixed(1) + "/10" : "No ratings yet" %>
        </p>
        <% if (place.communityRating !== null) { %>
          <p class="review-stars mb-1" aria-label="Community rating <%= place.communityRating.toFixed(1) %> out of 10">
            <% for (let i = 1; i <= 5; i += 1) { %>
              <span class="review-star <%= i <= communityStars ? "filled" : "" %>"><%- i <= communityStars ? "&#9733;" : "&#9734;" %></span>
            <% } %>
          </p>
        <% } %>
        <p class="text-body-secondary small mb-0">Based on <%= place.communityReviewCount %> community review<%= place.communityReviewCount === 1 ? "" : "s" %></p>
      </div>
    </div>
  </a>
</div>
