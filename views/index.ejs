<%- include("partials/header") %>

<section class="hero text-white text-center">
  <div class="container py-5">
    <h1 class="display-4 fw-bold mb-3">Find your next favorite cup ☕</h1>
    <p class="lead mb-4">
      Discover and rate the best coffee places around. Ranked by the community,
      out of 10.
    </p>
    <a href="/submit" class="btn btn-light btn-lg fw-semibold">
      Rate a Coffee Place
    </a>
  </div>
</section>

<div class="container py-5">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h2 class="h3 mb-0">The Rankings</h2>
    <span class="badge text-bg-secondary rounded-pill">
      <%= places.length %> place<%= places.length === 1 ? "" : "s" %>
    </span>
  </div>

  <% if (places.length === 0) { %>
    <div class="text-center text-body-secondary py-5">
      <p class="fs-5 mb-3">No coffee places yet.</p>
      <a href="/submit" class="btn btn-primary">Be the first to add one</a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% places.forEach(function (place, index) { %>
        <% var isEditing = typeof editingId !== "undefined" && editingId && String(editingId) === String(place._id); %>
        <% var ev = isEditing ? editValues : {
          name: place.name,
          location: place.location,
          ordered: place.ordered,
          costRating: place.costRating,
          tasteRating: place.tasteRating,
          locationRating: place.locationRating,
          vibeRating: place.vibeRating,
          notes: place.notes,
        }; %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm coffee-card">
            <div class="card-body d-flex flex-column">
              <div class="view-mode d-flex flex-column flex-grow-1<%= isEditing ? " d-none" : "" %>" id="view-<%= place._id %>">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <span class="rank-badge">#<%= index + 1 %></span>
                  <span class="rating-pill" title="Overall rating out of 10">
                    <%= place.overallRating.toFixed(1) %><small>/10</small>
                  </span>
                </div>
                <h3 class="h5 card-title mb-1"><%= place.name %></h3>
                <% if (place.location) { %>
                  <p class="text-body-secondary small mb-2">
                    📍 <%= place.location %>
                  </p>
                <% } %>
                <% if (place.ordered) { %>
                  <p class="small mb-2">
                    <span class="fw-semibold">☕ Ordered:</span> <%= place.ordered %>
                  </p>
                <% } %>
                <div class="row row-cols-2 g-2 mb-2 category-ratings">
                  <div class="col">
                    <div class="category-rating">
                      <span class="category-label">Cost</span>
                      <span class="category-score"><%= place.costRating.toFixed(1) %></span>
                    </div>
                  </div>
                  <div class="col">
                    <div class="category-rating">
                      <span class="category-label">Taste</span>
                      <span class="category-score"><%= place.tasteRating.toFixed(1) %></span>
                    </div>
                  </div>
                  <div class="col">
                    <div class="category-rating">
                      <span class="category-label">Location</span>
                      <span class="category-score"><%= place.locationRating.toFixed(1) %></span>
                    </div>
                  </div>
                  <div class="col">
                    <div class="category-rating">
                      <span class="category-label">Vibe</span>
                      <span class="category-score"><%= place.vibeRating.toFixed(1) %></span>
                    </div>
                  </div>
                </div>
                <% if (place.notes) { %>
                  <p class="card-text flex-grow-1"><%= place.notes %></p>
                <% } else { %>
                  <div class="flex-grow-1"></div>
                <% } %>
                <% if (typeof user !== "undefined" && user) { %>
                  <div class="d-flex gap-2 mt-3">
                    <button
                      type="button"
                      class="btn btn-sm btn-outline-secondary"
                      onclick="toggleEdit('<%= place._id %>')"
                    >
                      Edit
                    </button>
                    <form
                      action="/places/<%= place._id %>?_method=DELETE"
                      method="POST"
                      onsubmit="return confirm('Remove this place?');"
                    >
                      <button type="submit" class="btn btn-sm btn-outline-danger">
                        Remove
                      </button>
                    </form>
                  </div>
                <% } %>
              </div>

              <div class="edit-mode<%= isEditing ? "" : " d-none" %>" id="edit-<%= place._id %>">
                <% if (isEditing && editErrors && editErrors.length) { %>
                  <div class="alert alert-danger py-2 px-2 small mb-2">
                    <ul class="mb-0 ps-3">
                      <% editErrors.forEach(function (error) { %>
                        <li><%= error.msg %></li>
                      <% }); %>
                    </ul>
                  </div>
                <% } %>
                <form action="/places/<%= place._id %>?_method=PUT" method="POST">
                  <div class="mb-2">
                    <label class="form-label small mb-1">Name</label>
                    <input
                      type="text"
                      class="form-control form-control-sm"
                      name="name"
                      maxlength="120"
                      value="<%= ev.name %>"
                      required
                    />
                  </div>
                  <div class="mb-2">
                    <label class="form-label small mb-1">Location</label>
                    <input
                      type="text"
                      class="form-control form-control-sm"
                      name="location"
                      maxlength="160"
                      value="<%= ev.location %>"
                    />
                  </div>
                  <div class="mb-2">
                    <label class="form-label small mb-1">What was ordered</label>
                    <input
                      type="text"
                      class="form-control form-control-sm"
                      name="ordered"
                      maxlength="200"
                      value="<%= ev.ordered %>"
                    />
                  </div>
                  <div class="row g-2 mb-2">
                    <div class="col-6">
                      <label class="form-label small mb-1">Cost (0-10)</label>
                      <input
                        type="number"
                        class="form-control form-control-sm"
                        name="costRating"
                        min="0"
                        max="10"
                        step="0.1"
                        value="<%= ev.costRating %>"
                        required
                      />
                    </div>
                    <div class="col-6">
                      <label class="form-label small mb-1">Taste (0-10)</label>
                      <input
                        type="number"
                        class="form-control form-control-sm"
                        name="tasteRating"
                        min="0"
                        max="10"
                        step="0.1"
                        value="<%= ev.tasteRating %>"
                        required
                      />
                    </div>
                    <div class="col-6">
                      <label class="form-label small mb-1">Location (0-10)</label>
                      <input
                        type="number"
                        class="form-control form-control-sm"
                        name="locationRating"
                        min="0"
                        max="10"
                        step="0.1"
                        value="<%= ev.locationRating %>"
                        required
                      />
                    </div>
                    <div class="col-6">
                      <label class="form-label small mb-1">Vibe (0-10)</label>
                      <input
                        type="number"
                        class="form-control form-control-sm"
                        name="vibeRating"
                        min="0"
                        max="10"
                        step="0.1"
                        value="<%= ev.vibeRating %>"
                        required
                      />
                    </div>
                  </div>
                  <div class="mb-2">
                    <label class="form-label small mb-1">Notes</label>
                    <textarea
                      class="form-control form-control-sm"
                      name="notes"
                      rows="2"
                      maxlength="500"
                    ><%= ev.notes %></textarea>
                  </div>
                  <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary">Save</button>
                    <button
                      type="button"
                      class="btn btn-sm btn-outline-secondary"
                      onclick="toggleEdit('<%= place._id %>')"
                    >
                      Cancel
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  function toggleEdit(id) {
    document.getElementById("view-" + id).classList.toggle("d-none");
    document.getElementById("edit-" + id).classList.toggle("d-none");
  }
</script>

<%- include("partials/footer") %>
