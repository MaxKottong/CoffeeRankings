<%- include("partials/header") %>

<section class="landing-hero">
  <div class="hero-wave hero-wave-top-1"></div>
  <div class="hero-wave hero-wave-top-2"></div>
  <div class="hero-wave hero-wave-top-3"></div>
  <div class="container hero-content">
    <p class="hero-kicker">Max &amp; Margo Coffee Reviews</p>
    <h1 class="hero-title">Honest reviews.<br />Better coffee.</h1>
    <p class="hero-copy">Your most recent coffee story, at a glance.</p>
    <% if (typeof user !== "undefined" && user) { %>
      <a href="/submit" class="btn btn-primary btn-lg">Share a Review</a>
    <% } else { %>
      <a href="/reviews" class="btn btn-primary btn-lg">Browse Reviews</a>
    <% } %>
  </div>
</section>

<section class="container featured-wrap">
  <div class="section-title-row">
    <span class="line"></span>
    <p class="section-title">Latest Review</p>
    <span class="line"></span>
  </div>
</section>

<div class="container pb-5">
  <% if (latestPlace) { %>
    <article class="featured-card">
      <aside class="featured-meta">
        <div class="meta-block">
          <p class="meta-label">Origin</p>
          <p class="meta-value"><%= latestPlace.location || "Unknown" %></p>
        </div>
        <div class="meta-block">
          <p class="meta-label">Latest By</p>
          <p class="meta-value"><%= latestPlace.latestReview && latestPlace.latestReview.ownerName ? latestPlace.latestReview.ownerName : "Max or Margo" %></p>
        </div>
        <div class="meta-block">
          <p class="meta-label">Community</p>
          <p class="meta-value">
            <%= latestPlace.communityRating !== null ? latestPlace.communityRating.toFixed(1) + "/10" : "No ratings yet" %>
          </p>
        </div>
        <div class="meta-block">
          <p class="meta-label">Total Reviews</p>
          <p class="meta-value"><%= latestPlace.communityReviewCount %> community</p>
        </div>
      </aside>
      <div class="featured-body">
        <h2><%= latestPlace.name %></h2>
        <p class="featured-location"><%= latestPlace.location || "Location not listed" %></p>
        <p class="featured-notes">
          <%= latestPlace.latestReview && latestPlace.latestReview.notes ? latestPlace.latestReview.notes : "No notes yet for this place." %>
        </p>
        <div class="featured-rating-box">
          <p class="meta-label mb-1">Latest Score</p>
          <p class="featured-score">
            <%= latestPlace.latestReview ? latestPlace.latestReview.overallRating.toFixed(1) + "/10" : "-" %>
          </p>
        </div>
        <a href="/places/<%= latestPlace.anchorId %>" class="btn btn-outline-secondary mt-3">View Full Review</a>
      </div>
      <div class="featured-image-wrap">
        <% if (latestPlace.image) { %>
          <img
            src="/places/<%= latestPlace.anchorId %>/image/<%= latestPlace.image._id %>"
            alt="Photo of <%= latestPlace.name %>"
            class="featured-image"
            loading="lazy"
          />
        <% } else { %>
          <div class="featured-image featured-image-placeholder">No photo yet</div>
        <% } %>
      </div>
    </article>
  <% } else { %>
    <article class="featured-card">
      <div class="featured-body">
        <h2>No reviews yet</h2>
        <p class="featured-notes">Once Max or Margo posts a review, it will appear here automatically.</p>
        <a href="/reviews" class="btn btn-outline-secondary mt-3">Open Reviews Page</a>
      </div>
    </article>
  <% } %>
</div>

<section id="about" class="about-band py-5">
  <div class="container">
    <div class="row g-4 text-center text-lg-start">
      <div class="col-12 col-lg-4">
        <div class="about-item">
          <div class="about-icon">01</div>
          <h3>Find</h3>
          <p>Discover top-rated coffee spots near you and around the world.</p>
        </div>
      </div>
      <div class="col-12 col-lg-4">
        <div class="about-item">
          <div class="about-icon">02</div>
          <h3>Review</h3>
          <p>Share your experience and help others find their perfect cup.</p>
        </div>
      </div>
      <div class="col-12 col-lg-4">
        <div class="about-item">
          <div class="about-icon">03</div>
          <h3>Enjoy</h3>
          <p>Life is too short for bad coffee. Sip happy and stay caffeinated.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
